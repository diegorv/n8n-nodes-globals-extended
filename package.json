{
  "name": "n8n-nodes-globals-extended",
  "version": "2.0.0",
  "description": "N8N community node that allows users to create global constants and use them in all their workflows",
  "keywords": [
    "n8n-community-node-package"
  ],
  "license": "MIT",
  "homepage": "https://github.com/diegorv/n8n-nodes-globals-extended",
  "author": {
    "name": "Diego R. v.",
    "email": "eu@diegorv.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/diegorv/n8n-nodes-globals-extended.git"
  },
  "main": "index.js",
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "run-dev": "npm run build && cross-env N8N_LOG_LEVEL=debug n8n start",
    "run-dev-tunnel": "npm run build && cross-env N8N_LOG_LEVEL=debug n8n start --tunnel",
    "format": "prettier nodes credentials --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json",
    "semantic-release": "semantic-release"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GlobalConstantsCredentials.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GlobalConstants/GlobalConstants.node.js"
    ]
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@types/jest": "^30.0.0",
    "@typescript-eslint/parser": "^8.59.1",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "cross-env": "^10.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.6",
    "gulp": "^5.0.1",
    "jest": "^30.3.0",
    "n8n-workflow": "*",
    "prettier": "^3.8.3",
    "semantic-release": "^25.0.3",
    "semantic-release-replace-plugin": "^1.2.7",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
